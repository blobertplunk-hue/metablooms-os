{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/audit/audit_bundle.schema.json",
  "title": "MetaBlooms AUDIT Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_type",
    "bundle_version",
    "component_id",
    "scope",
    "inputs_audited",
    "checks",
    "findings",
    "verdict",
    "evidence",
    "timestamp"
  ],
  "properties": {
    "bundle_type": {
      "const": "audit_bundle"
    },
    "bundle_version": {
      "const": "1.1"
    },
    "component_id": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string",
      "minLength": 10
    },
    "inputs_audited": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "checks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "target",
          "method",
          "expected",
          "observed",
          "status"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 3
          },
          "target": {
            "type": "string",
            "minLength": 3
          },
          "method": {
            "type": "string",
            "minLength": 10
          },
          "expected": {
            "type": "string",
            "minLength": 3
          },
          "observed": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "UNKNOWN"
            ]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "description",
          "evidence_refs",
          "impact"
        ],
        "properties": {
          "finding_id": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "impact": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "CONDITIONAL"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}