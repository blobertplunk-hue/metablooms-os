{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/preflight/preflight_bundle.schema.json",
  "title": "MetaBlooms PREFLIGHT Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_type",
    "bundle_version",
    "component_id",
    "checks"
  ],
  "properties": {
    "bundle_type": {
      "const": "preflight_bundle"
    },
    "bundle_version": {
      "const": "1.0"
    },
    "component_id": {
      "type": "string",
      "minLength": 3
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "purpose",
          "inputs_required",
          "validation_method",
          "fail_closed_condition",
          "artifacts_verified",
          "ecl_alignment"
        ],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "purpose": {
            "type": "string",
            "minLength": 10
          },
          "inputs_required": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "validation_method": {
            "type": "string",
            "minLength": 10
          },
          "fail_closed_condition": {
            "type": "string",
            "minLength": 5
          },
          "artifacts_verified": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "ecl_alignment": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rollback_step_ids",
              "observability_signal"
            ],
            "properties": {
              "rollback_step_ids": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "observability_signal": {
                "type": "string",
                "minLength": 3
              }
            }
          }
        }
      }
    }
  }
}