{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/execute/execute_bundle.schema.json",
  "title": "MetaBlooms EXECUTE Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_type",
    "bundle_version",
    "component_id",
    "execution_steps",
    "guards",
    "evidence_emitted",
    "rollback_alignment"
  ],
  "properties": {
    "bundle_type": {
      "const": "execute_bundle"
    },
    "bundle_version": {
      "const": "1.0"
    },
    "component_id": {
      "type": "string",
      "minLength": 3
    },
    "execution_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "description",
          "inputs",
          "outputs",
          "side_effects",
          "verification",
          "failure_modes"
        ],
        "properties": {
          "step_id": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "side_effects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "success_criteria",
              "evidence"
            ],
            "properties": {
              "method": {
                "type": "string",
                "minLength": 10
              },
              "success_criteria": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 5
                }
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "failure_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "guards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_emitted": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollback_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_step_ids",
        "post_execution_verification"
      ],
      "properties": {
        "rollback_step_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "post_execution_verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}