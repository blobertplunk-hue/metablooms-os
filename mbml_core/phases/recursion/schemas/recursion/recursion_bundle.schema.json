{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/recursion/recursion_bundle.schema.json",
  "title": "MetaBlooms RECURSION Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_type",
    "bundle_version",
    "component_id",
    "inputs",
    "signals",
    "analysis",
    "decisions",
    "actions",
    "verification",
    "learning",
    "timestamp"
  ],
  "properties": {
    "bundle_type": {
      "const": "recursion_bundle"
    },
    "bundle_version": {
      "const": "1.0"
    },
    "component_id": {
      "type": "string",
      "minLength": 3
    },
    "inputs": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "telemetry",
        "audit_findings",
        "gate_failures"
      ],
      "properties": {
        "telemetry": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "audit_findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "gate_failures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "root_causes",
        "confidence"
      ],
      "properties": {
        "method": {
          "enum": [
            "RCA",
            "DMAIC",
            "A3",
            "FMEA"
          ]
        },
        "root_causes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 10
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "description",
          "justification",
          "risk"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 3
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "justification": {
            "type": "string",
            "minLength": 10
          },
          "risk": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH"
            ]
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "target_stage",
          "change_type",
          "expected_effect"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "minLength": 3
          },
          "target_stage": {
            "enum": [
              "SEE",
              "MMD",
              "PLAN",
              "PREFLIGHT",
              "EXECUTE",
              "BTS",
              "AUDIT",
              "ECL"
            ]
          },
          "change_type": {
            "enum": [
              "SCHEMA",
              "GATE",
              "TELEMETRY",
              "PROCESS",
              "INVARIANT"
            ]
          },
          "expected_effect": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "success_criteria",
        "rollback"
      ],
      "properties": {
        "method": {
          "enum": [
            "A/B",
            "CANARY",
            "REPLAY",
            "SIMULATION"
          ]
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "rollback": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "insights",
        "new_invariants",
        "documentation_updates"
      ],
      "properties": {
        "insights": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 10
          }
        },
        "new_invariants": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "documentation_updates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}