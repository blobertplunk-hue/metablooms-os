{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/ecl/failure_mode_registry.schema.json",
  "title": "ECL Failure Mode Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "component_id",
    "failure_modes"
  ],
  "properties": {
    "artifact_type": {
      "const": "failure_mode_registry"
    },
    "artifact_version": {
      "const": "1.1"
    },
    "component_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "trigger",
          "impact",
          "detectability",
          "severity_0_5",
          "mitigation",
          "test_case",
          "telemetry_signal",
          "related_invariant_ids",
          "related_operation_names",
          "rollback_step_ids"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z0-9\\-_.]{3,64}$"
          },
          "name": {
            "type": "string",
            "minLength": 5
          },
          "trigger": {
            "type": "string",
            "minLength": 5
          },
          "impact": {
            "type": "string",
            "minLength": 5
          },
          "detectability": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "severity_0_5": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "mitigation": {
            "type": "string",
            "minLength": 5
          },
          "test_case": {
            "type": "string",
            "minLength": 5
          },
          "telemetry_signal": {
            "type": "string",
            "minLength": 3
          },
          "related_invariant_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9\\-_.]{3,64}$"
            }
          },
          "related_operation_names": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "rollback_step_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          }
        }
      }
    }
  }
}