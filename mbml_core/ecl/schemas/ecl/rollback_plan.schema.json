{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/ecl/rollback_plan.schema.json",
  "title": "ECL Rollback Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "component_id",
    "rollback_triggers",
    "rollback_steps",
    "post_rollback_verification",
    "safety_constraints"
  ],
  "properties": {
    "artifact_type": {
      "const": "rollback_plan"
    },
    "artifact_version": {
      "const": "1.1"
    },
    "component_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "rollback_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "rollback_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "action",
          "verification",
          "step_id"
        ],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "step_id": {
            "type": "string",
            "minLength": 2
          },
          "action": {
            "type": "string",
            "minLength": 5
          },
          "verification": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "post_rollback_verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "safety_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    }
  }
}