{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metablooms://schemas/ecl/observability_plan.schema.json",
  "title": "ECL Observability Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "component_id",
    "logging",
    "metrics",
    "tracing",
    "correlation"
  ],
  "properties": {
    "artifact_type": {
      "const": "observability_plan"
    },
    "artifact_version": {
      "const": "1.1"
    },
    "component_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "required_fields",
        "levels",
        "redaction_rules"
      ],
      "properties": {
        "format": {
          "enum": [
            "jsonl",
            "json",
            "ndjson"
          ]
        },
        "required_fields": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "debug",
              "info",
              "warn",
              "error"
            ]
          }
        },
        "redaction_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_metrics",
        "units",
        "sampling"
      ],
      "properties": {
        "required_metrics": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "units": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "sampling": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "tracing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "span_model"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "span_model": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id_field",
        "propagation"
      ],
      "properties": {
        "correlation_id_field": {
          "type": "string",
          "minLength": 2
        },
        "propagation": {
          "type": "string",
          "minLength": 5
        }
      }
    }
  }
}