{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetaBlooms Ledger Event",
  "type": "object",
  "required": [
    "event_id",
    "ts",
    "event_type",
    "actor",
    "artifact"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "BOOT",
        "ZOOP",
        "VALIDATION",
        "DELTA_APPLY",
        "INDEX_BUILD",
        "ERROR"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}