#!/data/data/com.termux/files/usr/bin/bash
# ──────────────────────────────────────────────────────────────
# mb-push — one-shot upload of metablooms-os to GitHub from Termux
#
# Usage:
#   mb-push <file> <owner/repo> [branch]
#
# Example:
#   mb-push ~/storage/shared/metablooms-os.zip blobertplunk-hue/metablooms-os main
#
# Handles files >100MB via Git LFS. Falls back to release asset upload.
# ──────────────────────────────────────────────────────────────
set -euo pipefail

FILE="${1:?Usage: mb-push <file> <owner/repo> [branch]}"
REPO="${2:?Usage: mb-push <file> <owner/repo> [branch]}"
BRANCH="${3:-main}"

# ── Preflight ──────────────────────────────────────────────────

if [ ! -f "$FILE" ]; then
  echo "ERROR: File not found: $FILE"
  exit 1
fi

SIZE_BYTES=$(stat -c%s "$FILE" 2>/dev/null || stat -f%z "$FILE")
SIZE_MB=$(( SIZE_BYTES / 1048576 ))
BASENAME=$(basename "$FILE")

echo "File:   $BASENAME ($SIZE_MB MB)"
echo "Repo:   $REPO"
echo "Branch: $BRANCH"
echo ""

# ── Install deps if missing ────────────────────────────────────

install_if_missing() {
  if ! command -v "$1" &>/dev/null; then
    echo "Installing $1…"
    pkg install -y "$1"
  fi
}

install_if_missing git
install_if_missing gh

# ── Auth check ─────────────────────────────────────────────────

if ! gh auth status &>/dev/null; then
  echo "Not authenticated. Running gh auth login…"
  gh auth login
fi

# ── Route by size ──────────────────────────────────────────────

if [ "$SIZE_BYTES" -le 104857600 ]; then
  # ≤100 MB — regular git push works
  echo "Size ≤ 100 MB — using regular git push."
  NEEDS_LFS=false
else
  # >100 MB — need Git LFS
  echo "Size > 100 MB — using Git LFS."
  NEEDS_LFS=true
  install_if_missing git-lfs
fi

# ── Clone, add, push ──────────────────────────────────────────

WORKDIR=$(mktemp -d)
trap 'rm -rf "$WORKDIR"' EXIT

echo ""
echo "Cloning $REPO (shallow)…"
gh repo clone "$REPO" "$WORKDIR" -- --depth=1 --branch="$BRANCH" --single-branch

cd "$WORKDIR"

if [ "$NEEDS_LFS" = true ]; then
  echo "Initializing Git LFS…"
  git lfs install --local
  # Track by exact filename to avoid polluting .gitattributes for other files
  git lfs track "$BASENAME"
  git add .gitattributes
fi

echo "Copying file…"
cp "$FILE" "$WORKDIR/$BASENAME"

git add "$BASENAME"

# Check if there's actually something to commit
if git diff --cached --quiet; then
  echo "File already exists with identical content. Nothing to push."
  exit 0
fi

SHA256=$(sha256sum "$WORKDIR/$BASENAME" | cut -d' ' -f1)

git commit -m "Upload $BASENAME (${SIZE_MB}MB)

sha256: $SHA256"

echo ""
echo "Pushing to $REPO/$BRANCH…"

RETRY=0
MAX_RETRIES=4
DELAY=2

while [ $RETRY -lt $MAX_RETRIES ]; do
  if git push origin "$BRANCH"; then
    echo ""
    echo "Done. $BASENAME pushed to $REPO ($BRANCH)."
    echo "SHA-256: $SHA256"
    exit 0
  fi
  RETRY=$((RETRY + 1))
  if [ $RETRY -lt $MAX_RETRIES ]; then
    echo "Push failed. Retrying in ${DELAY}s… ($RETRY/$MAX_RETRIES)"
    sleep $DELAY
    DELAY=$((DELAY * 2))
  fi
done

echo ""
echo "Git push failed after $MAX_RETRIES attempts."
echo "Falling back to GitHub Release upload…"

# ── Fallback: upload as release asset ──────────────────────────

TAG="upload-$(date +%Y%m%d-%H%M%S)"
echo "Creating release $TAG…"

gh release create "$TAG" \
  --repo "$REPO" \
  --title "Upload: $BASENAME" \
  --notes "Uploaded from Termux.

sha256: $SHA256
size: ${SIZE_MB}MB" \
  "$WORKDIR/$BASENAME"

echo ""
echo "Done. Uploaded as release asset: $TAG"
echo "SHA-256: $SHA256"
