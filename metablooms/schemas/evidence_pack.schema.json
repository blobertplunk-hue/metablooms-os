{
  "$id": "metablooms://schemas/evidence_pack.schema.json",
  "title": "MetaBlooms Evidence Pack (Risk Acceptance)",
  "type": "object",
  "properties": {
    "risk_acceptance": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "owner",
        "justification",
        "evidence_ids",
        "expires_at"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "justification": {
          "type": "string",
          "minLength": 10
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}