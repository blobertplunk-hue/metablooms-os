{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetaBlooms PRR Report v1",
  "type": "object",
  "required": ["run_id", "created_utc", "inputs", "findings", "mmt_queue_path"],
  "properties": {
    "run_id": {"type": "string"},
    "created_utc": {"type": "string"},
    "inputs": {
      "type": "object",
      "properties": {
        "evidence_log_path": {"type": "string"},
        "ledger_path": {"type": "string"},
        "diff_manifest_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "type", "summary", "severity", "evidence_refs"],
        "properties": {
          "finding_id": {"type": "string"},
          "type": {"type": "string"},
          "summary": {"type": "string"},
          "severity": {"type": "string", "enum": ["LOW", "MED", "HIGH", "CRIT"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "inference": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "mmt_queue_path": {"type": "string"}
  },
  "additionalProperties": false
}
