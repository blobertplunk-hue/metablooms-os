        "constraints",
        "teks",
        "content_type"
      ],
      "output_types": [
        "template_id"
      ],
      "description": "Select page kit / scaffold template."
    },
    {
      "id": "S3",
      "name": "Embed Vet",
      "input_types": [
        "embed_candidates"
      ],
      "output_types": [
        "vet_result"
      ],
      "description": "Fail-closed vetting of iframes/videos."
    },
    {
      "id": "S4",
      "name": "Emit Artifact",
      "input_types": [
        "template_id",
        "assets"
      ],
      "output_types": [
        "artifact"
      ],
      "description": "Generate paste-ready HTML and manifest."
    },
    {
      "id": "S5",
      "name": "Index Append (Deferred)",
      "input_types": [
        "artifact_manifest",
        "delta_payload"
      ],
      "output_types": [
        "index_update"
      ],
      "description": "Append new pages to TEKS inventory at delta-time."
    }
  ],
