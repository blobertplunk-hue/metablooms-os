{
  "version": "v1",
  "pipe_sections_reference": [
    {
      "id": "S0",
      "name": "Intent Parse",
      "input_types": [
        "utterance"
      ],
      "output_types": [
        "intent_spec"
      ],
      "description": "Normalize operator intent and parameters."
    },
    {
      "id": "S1",
      "name": "Constraint Bind",
      "input_types": [
        "intent_spec",
        "platform"
      ],
      "output_types": [
        "constraints"
      ],
      "description": "Apply platform and policy constraints."
    },
    {
      "id": "S2",
      "name": "Template Select",
